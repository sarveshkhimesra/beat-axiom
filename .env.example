# Beat AXIOM — Environment Variables
# Copy this file to .env.local and fill in your values.
# .env.local is git-ignored — your keys never get committed.

# ─── AI PROVIDER (pick ONE of the three options below) ───────────────────────

# Option A: Direct Anthropic API (simplest)
# ANTHROPIC_API_KEY=sk-ant-...

# Option B: Azure-hosted Anthropic
# AZURE_ANTHROPIC_ENDPOINT=https://your-resource.services.ai.azure.com/anthropic/
# AZURE_ANTHROPIC_API_KEY=your-key
# AZURE_ANTHROPIC_MODEL=your-deployment-name

# Option C: LiteLLM / OpenAI-compatible proxy (routes via x-litellm-api-key header)
# LITELLM_BASE_URL=https://your-proxy.example.com
# LITELLM_API_KEY=your-key

# Priority: LiteLLM > Azure > Direct. First one with values wins.

# ─── MODEL NAMES ─────────────────────────────────────────────────────────────

# Default model (used if the per-route overrides below aren't set).
ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional: use a cheaper model for buyer conversation turns (high-volume path).
# DUEL_AVATAR_MODEL=claude-haiku-4-5

# Optional: use a stronger model for the verdict (single expensive call).
# DUEL_VERDICT_MODEL=claude-sonnet-4-6

# ─── REDIS (optional in dev — falls back to in-memory) ───────────────────────

# Upstash Redis for session persistence, percentile tracking, and rate-limiting.
# Without this, sessions are stored in-memory (lost on restart). Required for production.
# UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-token

# ─── ABUSE PROTECTION (optional) ─────────────────────────────────────────────

# Cloudflare Turnstile — bot protection before duel starts.
# Without this, only IP-based rate-limiting protects the API.
# TURNSTILE_SECRET_KEY=
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# ─── APP CONFIG ──────────────────────────────────────────────────────────────

# Base URL (auto-detected on Vercel; set manually for other hosts).
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Kill switch — set to "true" to pause all duels (shows "AXIOM is resting" page).
# DUEL_PAUSED=
