# Copy this file to .env.local and fill in your own values.
# .env.local is git-ignored so your real keys never get committed.

# Anthropic Claude API (https://console.anthropic.com)
ANTHROPIC_API_KEY=

# Pusher (https://pusher.com) — real-time sync between devices
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=

# Upstash Redis (https://upstash.com) — session state persistence
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Base URL used by the app (e.g. http://localhost:3000 for dev)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Azure-hosted Anthropic (optional — alternative to ANTHROPIC_API_KEY)
AZURE_ANTHROPIC_ENDPOINT=
AZURE_ANTHROPIC_API_KEY=
AZURE_ANTHROPIC_MODEL=
